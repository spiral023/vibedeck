# VibeDeck Environment Variables
# Kopiere diese Datei zu .env.local für lokale Entwicklung

# Next.js
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Server Configuration
PORT=3000
HOSTNAME=0.0.0.0

# Optional: Weitere Umgebungsvariablen können hier hinzugefügt werden

# X (Twitter) API — App-only Bearer Token für scripts/ingest-x.mjs
# X Developer Portal → App "vibedeck-ingest" → Keys and tokens → Bearer Token
X_BEARER_TOKEN=
